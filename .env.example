# COPY FILE INI MENJADI `.env` UNTUK MENJALANKAN SCRAPER LOKAL ANDA
# JANGAN PERNAH MENGKOMIT `.env` KE GITHUB!

JOBSTREET_BEARER_TOKEN="Bearer eyJhb... (ISI DENGAN TOKEN ANDA)"

# Silakan diisi dengan nilai Cookie dari Network Tab (dalam satu baris panjang)
# Contoh: JOBSTREET_COOKIES="sol_id=123; _ga=456; last-known-sol-user-id=789;"
JOBSTREET_COOKIES=""
